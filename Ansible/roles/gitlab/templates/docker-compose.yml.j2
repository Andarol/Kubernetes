services:
  gitlab:
    image: {{ gitlab_image }}
    container_name: {{ gitlab_container_name }}
    restart: always
    hostname: {{ ansible_host }}
    shm_size: {{ gitlab_shm_size }}
    environment:
      GITLAB_OMNIBUS_CONFIG: |
        external_url '{{ gitlab_external_url }}'
        gitlab_rails['gitlab_shell_ssh_port'] = {{ gitlab_ssh_port }}
        registry_external_url 'http://{{ ansible_host }}:{{ gitlab_registry_port }}'
    ports:
      - "{{ gitlab_http_port }}:80"
      - "{{ gitlab_https_port }}:443"
      - "{{ gitlab_ssh_port }}:22"
      - "{{ gitlab_registry_port }}:{{ gitlab_registry_port }}"
    volumes:
      - {{ gitlab_base_dir }}/config:/etc/gitlab
      - {{ gitlab_base_dir }}/logs:/var/log/gitlab
      - {{ gitlab_base_dir }}/data:/var/opt/gitlab